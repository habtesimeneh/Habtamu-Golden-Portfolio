# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret used to sign admin session tokens.
# REQUIRED in production. Use a long random value, e.g. `openssl rand -hex 48`.
JWT_SECRET="change_me_to_a_long_random_value"

# ADMIN_PASSWORD: Initial password for the seeded admin user.
# If unset, a random password is generated and printed to the server logs once.
ADMIN_PASSWORD=""

# ALLOWED_ORIGINS: Comma-separated list of origins allowed to call the API
# cross-origin (CORS). Leave empty for same-origin only. e.g.
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
ALLOWED_ORIGINS=""

# CLOUDINARY: Media upload credentials. Never commit real values.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# DATABASE CONFIGURATION FOR LOCAL VS CODE / MAMP INTEGRATION
# Set DB_TYPE to "mysql" to enable MAMP/MySQL connectivity. Default is "sqlite"
DB_TYPE="sqlite"
DB_HOST="localhost"
DB_PORT=3306
DB_USER="root"
DB_PASSWORD="root"
DB_NAME="habtamu_gold_portfolio"
